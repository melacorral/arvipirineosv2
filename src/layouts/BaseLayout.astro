---
// src/layouts/BaseLayout.astro
import BaseHead from "@/components/BaseHead.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import CookieBanner from "@/components/CookieBanner.astro";
import { GoogleAnalytics } from "astro-google-analytics";
import "@/styles/global.css";

interface Props {
  title: string;
  description?: string;
}
const { title, description } = Astro.props;
---
<html lang="es">
  <head>
    <BaseHead title={title} description={description} />
    <GoogleAnalytics id="G-L9SLY17ZWN" />
    <slot name="head" />
  </head>
  <body>
    <Header />
    <main><slot /></main>
    <Footer />
    <CookieBanner />

    <!-- ═══ Lenis + GSAP ScrollTrigger + Reveal + Parallax ═══ -->
    <script>
      import gsap from "gsap";
      import { ScrollTrigger } from "gsap/ScrollTrigger";
      import Lenis from "lenis";

      gsap.registerPlugin(ScrollTrigger);

      // ── Lenis smooth scroll ──
      const lenis = new Lenis({
        duration: 1.1,
        easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
        smoothTouch: false,
      });

      lenis.on("scroll", ScrollTrigger.update);
      gsap.ticker.add((time) => lenis.raf(time * 1000));
      gsap.ticker.lagSmoothing(0);

      // ── Reveal de textos y bloques ──
      // toggleActions: play none none reverse → se activa al bajar, se revierte al subir
      gsap.utils.toArray<HTMLElement>(".reveal").forEach((el) => {
        gsap.fromTo(
          el,
          { y: 40, opacity: 0 },
          {
            y: 0,
            opacity: 1,
            duration: 0.9,
            ease: "power3.out",
            scrollTrigger: {
              trigger: el,
              start: "top 88%",
              end: "top 20%",
              toggleActions: "play none none reverse",
            },
          }
        );
      });

      // ── Reveal de imágenes desde el centro (clip-path) ──
      gsap.utils.toArray<HTMLElement>(".imagen-reveal-center").forEach((img) => {
        const contenedor = img.closest(".contenedor-reveal-center") || img.parentElement;
        gsap.fromTo(
          img,
          { clipPath: "inset(50% 50% 50% 50%)", scale: 1.15 },
          {
            clipPath: "inset(0% 0% 0% 0%)",
            scale: 1,
            duration: 1.5,
            ease: "power3.inOut",
            scrollTrigger: {
              trigger: contenedor,
              start: "top 85%",
              end: "top 20%",
              toggleActions: "play none none reverse",
            },
          }
        );
      });

      // ── Reveal de imágenes desde un lado (clip-path lateral) ──
      gsap.utils.toArray<HTMLElement>(".imagen-reveal").forEach((img) => {
        const contenedor = img.closest(".contenedor-reveal") || img.closest(".contenedor-reveal-center") || img.parentElement;
        gsap.fromTo(
          img,
          { clipPath: "inset(0% 100% 0% 0%)", scale: 1.15 },
          {
            clipPath: "inset(0% 0% 0% 0%)",
            scale: 1,
            duration: 1.5,
            ease: "power3.inOut",
            scrollTrigger: {
              trigger: contenedor,
              start: "top 80%",
              end: "top 20%",
              toggleActions: "play none none reverse",
            },
          }
        );
      });

      // ── Parallax ──
      gsap.utils.toArray<HTMLElement>("[data-parallax]").forEach((el) => {
        const speed = parseFloat(el.dataset.parallax || "0.15");
        gsap.to(el, {
          yPercent: -speed * 100,
          ease: "none",
          scrollTrigger: {
            trigger: el.closest(".parallax-wrap") || el.parentElement,
            start: "top bottom",
            end: "bottom top",
            scrub: true,
          },
        });
      });

      // ── Smooth anchor scrolling via Lenis ──
      document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
        a.addEventListener("click", (e) => {
          const id = a.getAttribute("href");
          if (!id || id === "#") return;
          const target = document.querySelector(id);
          if (target) {
            e.preventDefault();
            lenis.scrollTo(target as HTMLElement, { offset: 0 });
          }
        });
      });
    </script>
  </body>
</html>
