---
// src/pages/blog/[slug].astro
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPosts, getPostBySlug, getFeaturedImage, getFeaturedImageAlt } from "@/lib/wordpress";

export async function getStaticPaths() {
  const posts = await getPosts(100);
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const post = await getPostBySlug(slug!);
if (!post) return Astro.redirect("/404");

const image = getFeaturedImage(post);
const alt = getFeaturedImageAlt(post);
const date = new Date(post.date).toLocaleDateString("es-ES", { year: "numeric", month: "long", day: "numeric" });
const description = post.excerpt.rendered.replace(/<[^>]*>/g, "").trim();
---
<BaseLayout
  title={`${post.title.rendered} — Arvipirineos`}
  description={description}
  image={image}
>
  <article class="section-y pt-36 lg:pt-44">
    <div class="container mx-auto max-w-3xl">
      <a href="/blog" class="text-[0.72rem] font-semibold uppercase tracking-[0.15em] text-black/40 no-underline transition-colors hover:text-black">← Volver al blog</a>
      <time class="mt-8 block text-[0.72rem] font-semibold uppercase tracking-[0.15em] text-black/35">{date}</time>
      <h1 class="mt-3 font-display text-[clamp(1.8rem,4vw,2.8rem)] leading-[1.2] text-black" set:html={post.title.rendered} />
      {image && (
        <div class="mt-8 aspect-[16/9] overflow-hidden rounded-lg">
          <img src={image} alt={alt} class="h-full w-full object-cover" />
        </div>
      )}
      <div class="wp-content mt-10 text-[1.05rem] leading-[1.8] text-black/65" set:html={post.content.rendered} />
    </div>
  </article>
</BaseLayout>
