---
// src/pages/index.astro
import BaseLayout from "@/layouts/BaseLayout.astro";
---
<BaseLayout title="Arvipirineos — Huevos ecológicos de la Jacetania">

  <!-- ═══════ HERO — Video de gallinas (SE MANTIENE) ═══════ -->
  <section class="relative flex min-h-[100svh] items-center justify-center overflow-hidden text-center">
    <video autoplay muted loop playsinline class="absolute inset-0 h-full w-full object-cover">
      <source src="https://arvipirineos.es/wp-content/uploads/2026/04/Gallinas-camperas-criadas-en-libertad.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/45"></div>
    <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/60 to-transparent"></div>

    <div class="container relative z-10 max-w-[720px] px-6">
      <span class="mb-8 inline-block rounded-full bg-mint/80 px-5 py-1.5 text-[0.75rem] font-semibold uppercase tracking-[0.15em] text-black opacity-0 animate-[fadeUp_0.8s_0.3s_forwards]">
        Avicultura artesanal · Santa Engracia de Jaca
      </span>
      <h1 class="font-display text-[clamp(2.4rem,5.5vw,4rem)] leading-[1.15] text-white opacity-0 animate-[fadeUp_0.8s_0.5s_forwards]">
        Huevos ecológicos de 1000 gallinas sueltas a los pies del Pirineo. <br>(viven como <em class="italic text-mint">reinas</em>.)
      </h1>
      <p class="mx-auto mt-6 max-w-lg text-[clamp(1rem,2vw,1.2rem)] leading-[1.8] text-white/80 opacity-0 animate-[fadeUp_0.8s_0.7s_forwards]">
         Carlos y Pepa recogen cada huevo a mano, le ponen el sello uno a uno y los bajan al mercado ellos mismos. <br>Así funciona Arvipirineos. <br>Así de sencillo y así de raro hoy en día.<br>
      </p>
      <a href="#comprar" class="mt-12 btn-primary opacity-0 animate-[fadeUp_0.8s_0.9s_forwards]">
        Quiero mi caja
      </a>
    </div>
  </section>

  <!-- ═══════ NUESTRA VERDAD ═══════ -->
  <section class="section-y">
    <div class="container">
      <div class="grid items-center gap-[clamp(2rem,5vw,4rem)] md:grid-cols-2">
        <div class="reveal">
          <span class="section-label">Nuestra verdad</span>
          <h2 class="section-title">Menos máquinas, más manos.</h2>
          <p class="text-[1.15rem] leading-[1.8] text-black/80">Somos Pepa y Carlos y en Arvipirineos hemos elegido el camino lento: una microgranja ecológica donde 1000 gallinas viven en verdadera libertad.</p>
          <p class="mt-4 text-[1.05rem] leading-[1.8] text-black/55">Aquí no hay cintas transportadoras ni procesos industriales. Hay avicultura artesanal, respeto absoluto por los ritmos de la naturaleza y el compromiso de ofrecerte un alimento honesto, sostenible y con el sabor de toda la vida.</p>
          <p class="mt-6 font-display text-[1.1rem] italic text-egg">Más que una granja, es nuestra forma de cuidar la tierra.</p>
        </div>
        <div class="contenedor-reveal overflow-hidden rounded-2xl">
          <img
            src="https://arvipirineos.es/wp-content/uploads/2024/08/photo_2024-08-06_14-32-50.jpg"
            alt="Pepa y Carlos en la granja Arvipirineos"
            class="imagen-reveal h-full w-full object-cover"
           
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════ CÓMO VIVEN LAS CHICAS ═══════ -->
  <section class="section-y bg-mint">
    <div class="container">
      <div class="reveal mb-10 max-w-[620px]">
        <span class="section-label !text-black/35">Bienestar animal</span>
        <h2 class="section-title">1000 gallinas que viven como reinas a los pies del Pirineo Aragonés</h2>
      </div>
      <div class="mt-16 grid gap-6 sm:grid-cols-3">
        
        <div class="reveal">
          <div class="h-full rounded-2xl border border-black/5 bg-white p-7 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_12px_36px_rgba(16,30,32,0.06)]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-egg/15">
              <svg class="h-6 w-6 text-black/80" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="4"></circle>
                <path d="M12 2v2"></path><path d="M12 20v2"></path>
                <path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path>
                <path d="M2 12h2"></path><path d="M20 12h2"></path>
                <path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
              </svg>
            </div>
            <h3 class="mb-2 font-display text-[1.25rem] text-black">Cero jaulas. Cero estrés.</h3>
            <p class="text-[0.95rem] leading-[1.6] text-black/60">
              Nuestras chicas corretean, escarban y se dan baños de arena libres todo el día.
            </p>
          </div>
        </div>

        <div class="reveal">
          <div class="h-full rounded-2xl border border-black/5 bg-white p-7 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_12px_36px_rgba(16,30,32,0.06)]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-mint/50">
              <svg class="h-6 w-6 text-black/80" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
                <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
              </svg>
            </div>
            <h3 class="mb-2 font-display text-[1.25rem] text-black">Ritmo natural</h3>
            <p class="text-[0.95rem] leading-[1.6] text-black/60">
              No forzamos la puesta. Respetamos su ciclo biológico: ponen cuando la naturaleza lo dicta.
            </p>
          </div>
        </div>

        <div class="reveal">
          <div class="h-full rounded-2xl border border-black/5 bg-white p-7 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_12px_36px_rgba(16,30,32,0.06)]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-egg/15">
              <svg class="h-6 w-6 text-black/80" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24">
                <path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"></path>
                <path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"></path>
                <path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"></path>
                <path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"></path>
                <path d="M6 11V6a2 2 0 0 1 2-2v0"></path><path d="M6 11V6a2 2 0 0 1 2-2v0"></path>
              </svg>
            </div>
            <h3 class="mb-2 font-display text-[1.25rem] text-black">Recogida manual</h3>
            <p class="text-[0.95rem] leading-[1.6] text-black/60">
              Recogemos cada huevo uno a uno, a mano. Sin cintas transportadoras ni máquinas.
            </p>
          </div>
        </div>

      </div>
  </section>

 <section class="section-y relative overflow-hidden bg-mint-light text-black">
    <div class="container relative z-10">
      <div class="grid items-center gap-[clamp(2rem,5vw,4rem)] md:grid-cols-2">
        
        <div class="reveal">
          <span class="section-label">Producto artesanal</span>
          <h2 class="section-title">El sabor de lo hecho a mano</h2>
          
          <p class="text-[1.05rem] leading-[1.8] text-black/75">
            <strong class="text-black">¿Por qué son diferentes? Porque SON diferentes.</strong> El color intenso de la yema y su sabor auténtico solo se consiguen con gallinas felices que comen pasto.
          </p>
          <p class="mt-4 text-[1.05rem] leading-[1.8] text-black/75">
            Nuestra producción es limitada porque apostamos por la producción artesanal de proximidad y la distribución limitada.
          </p>
          
          <div class="mt-8 flex flex-col gap-6">
            
            <div class="flex gap-4">
              <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-egg/15">
                <svg class="h-5 w-5 text-black/80" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M18 11V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"></path><path d="M14 10V4a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"></path><path d="M10 10.5V6a2 2 0 0 0-2-2v0a2 2 0 0 0-2 2v0"></path><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"></path><path d="M6 11V6a2 2 0 0 1 2-2v0"></path><path d="M6 11V6a2 2 0 0 1 2-2v0"></path></svg>
              </span>
              <p class="text-[0.95rem] text-black/75">
                <strong class="block text-black">Recogida manual</strong>
                Recogemos cada huevo uno a uno, con mimo.
              </p>
            </div>

            <div class="flex gap-4">
              <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-mint/50">
                <svg class="h-5 w-5 text-black/80" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><path d="m9 11 3 3L22 4"></path></svg>
              </span>
              <p class="text-[0.95rem] text-black/75">
                <strong class="block text-black">Etiquetado manual</strong>
                Ponemos el sello de garantía a mano, validando frescura y calidad.
              </p>
            </div>

            <div class="flex gap-4">
              <span class="mt-0.5 flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-egg/15">
                <svg class="h-5 w-5 text-black/80" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M5 18H3c-.6 0-1-.4-1-1V7c0-.6.4-1 1-1h10c.6 0 1 .4 1 1v11"></path><path d="M14 9h4l4 4v5c0 .6-.4 1-1 1h-2"></path><circle cx="7" cy="18" r="2"></circle><circle cx="17" cy="18" r="2"></circle></svg>
              </span>
              <p class="text-[0.95rem] text-black/75">
                <strong class="block text-black">Sin intermediarios</strong>
                Del nido al mercado, directos a tu cocina.
              </p>
            </div>

          </div>
        </div>

        <div class="contenedor-reveal overflow-hidden rounded-2xl">
          <img
            src="https://arvipirineos.es/wp-content/uploads/2024/08/photo_2024-08-06_14-32-39-1.jpg"
            alt="Manos marcando un huevo ecológico con el sello de garantía de Arvipirineos"
            class="imagen-reveal h-full w-full object-cover"
          
          />
        </div>

      </div>
    </div>
  </section>

 <section class="section-y bg-mint-light overflow-hidden">
    <div class="container">
      <div class="grid items-center gap-[clamp(2rem,5vw,4rem)] md:grid-cols-2">
        
        <div class="reveal order-2 md:order-1">
          <span class="section-label">De la huerta</span>
          <h2 class="section-title text-black">Los espárragos más esperados de Jaca</h2>
          
          <p class="text-[1.1rem] leading-[1.8] text-black/70">
            La tierra de Santa Engracia no solo nos da huevos. Cultivamos espárragos orgánicos, tiernos y con el sabor auténtico de la huerta del Pirineo.
          </p>

          <div class="mt-10 rounded-2xl border border-black/5 bg-white p-8 shadow-sm">
            <h3 class="font-display text-[1.3rem] text-black">¿Quieres saber cuándo asoman?</h3>
            <p class="mt-3 text-[0.95rem] leading-[1.7] text-black/60">
              Al ser un cultivo 100% natural, su aparición es un evento limitado. ¡Avisamos en redes sociales en cuanto empieza la cosecha!
            </p>
            
            <div class="mt-8 flex flex-wrap gap-4">
              <a href="#" target="_blank" rel="noopener" class="group inline-flex items-center gap-3 rounded-full bg-black px-6 py-3 text-[0.9rem] font-bold text-white no-underline transition-all hover:-translate-y-1 hover:bg-egg hover:text-black">
                <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                Instagram
              </a>
            </div>
          </div>
        </div>

        <div class="contenedor-reveal order-1 overflow-hidden rounded-2xl md:order-2">
          <img
            src="https://arvipirineos.es/wp-content/uploads/2024/08/photo_2024-08-06_14-32-29.jpg"
            alt="Espárragos ecológicos Arvipirineos"
            class="imagen-reveal h-full w-full object-cover aspect-[4/5]"
          />
        </div>

      </div>
    </div>
  </section>

  <section class="section-y" id="comprar">
    <div class="container">
      
      <div class="reveal mb-10 max-w-[640px]">
        <span class="section-label">Kilómetro cero</span>
        <h2 class="section-title">Llévate el Pirineo a tu cocina</h2>
        <p class="text-[1.05rem] leading-[1.8] text-black/60">
          Nuestros huevos ecológicos vienen en packs de 6 y 10 unidades. No hacemos envíos, porque preferimos la venta de proximidad, reducir la huella de carbono y vernos las caras en el mercado.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        
        <div class="reveal">
          <div class="h-full rounded-2xl border border-black/5 bg-white p-8 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_12px_36px_rgba(16,30,32,0.06)]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-mint/50">
              <svg class="h-6 w-6 text-black/80" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M3 9h18v10a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V9Z"></path><path d="m3 9 2.45-4.9A2 2 0 0 1 7.24 3h9.52a2 2 0 0 1 1.8 1.1L21 9"></path><path d="M12 3v6"></path></svg>
            </div>
            <h3 class="font-display text-[1.25rem] text-black">Mercado Agroalimentario Unizar</h3>
            <p class="mt-1 text-[0.85rem] font-bold tracking-wide uppercase text-black/40">Zaragoza</p>
            <p class="mt-4 text-[0.95rem] leading-[1.6] text-black/60">
              Todos los viernes, de 9:00 a 13:00.<br>Ven, charlamos y te llevas tu caja.
            </p>
          </div>
        </div>

        <div class="reveal">
          <div class="h-full rounded-2xl border border-black/5 bg-white p-8 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_12px_36px_rgba(16,30,32,0.06)]">
            <div class="mb-5 flex h-12 w-12 items-center justify-center rounded-full bg-egg/15">
              <svg class="h-6 w-6 text-black/80" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
            </div>
            <h3 class="font-display text-[1.25rem] text-black">Tiendas especializadas</h3>
            <p class="mt-1 text-[0.85rem] font-bold tracking-wide uppercase text-black/40">Aragón</p>
            <p class="mt-4 text-[0.95rem] leading-[1.6] text-black/60">
              Encuéntranos en los principales comercios ecológicos y bio de Aragón.
            </p>
          </div>
        </div>

      </div>

      <div class="reveal mx-auto mt-12 max-w-[480px]">
        <div class="overflow-hidden rounded-2xl border border-black/5 bg-mint-light shadow-sm">
          
          <div class="flex items-center justify-between border-b border-black/5 px-6 py-5">
            <span class="text-[1.05rem] font-medium text-black">Caja de 6 huevos</span>
            <span class="rounded-full bg-egg px-4 py-1 font-display text-[1.2rem] text-black">2,00 €</span>
          </div>
          
          <div class="flex items-center justify-between px-6 py-5">
            <span class="text-[1.05rem] font-medium text-black">Caja de 10 huevos</span>
            <span class="rounded-full bg-egg px-4 py-1 font-display text-[1.2rem] text-black">3,30 €</span>
          </div>

        </div>
      </div>

    </div>
  </section>

 <section class="border-y border-black/5 bg-white/50 py-20">
    <div class="container">
      <h3 class="mb-12 text-center font-display text-[0.8rem] uppercase tracking-[0.25em] text-black/40">
        Nos has visto en
      </h3>
      
      <div class="flex flex-wrap items-center justify-center gap-x-20 gap-y-12">
        
        <div class="group flex h-16 w-44 items-center justify-center opacity-40 grayscale transition-all duration-500 hover:opacity-100 hover:grayscale-0">
          <img 
            src="https://arvipirineos.es/wp-content/uploads/2024/10/rural-forks.jpg" 
            alt="Rural forks" 
            class="max-h-full max-w-full object-contain transition-transform duration-300 group-hover:scale-110" 
          />
        </div>

        <div class="group flex h-16 w-44 items-center justify-center opacity-40 grayscale transition-all duration-500 hover:opacity-100 hover:grayscale-0">
          <img 
            src="https://arvipirineos.es/wp-content/uploads/2024/10/logo_heraldo_face.png" 
            alt="Heraldo de Aragón" 
            class="max-h-full max-w-full object-contain transition-transform duration-300 group-hover:scale-110" 
          />
        </div>

        <div class="group flex h-16 w-44 items-center justify-center opacity-40 grayscale transition-all duration-500 hover:opacity-100 hover:grayscale-0">
          <img 
            src="https://arvipirineos.es/wp-content/uploads/2025/09/images.webp" 
            alt="Aragón televisión" 
            class="max-h-full max-w-full object-contain transition-transform duration-300 group-hover:scale-110" 
          />
        </div>

        <div class="group flex h-16 w-44 items-center justify-center opacity-40 grayscale transition-all duration-500 hover:opacity-100 hover:grayscale-0">
          <img 
            src="https://arvipirineos.es/wp-content/uploads/2024/10/logo_cam_light.png" 
            alt="CAM: Calidad agroalimentaria" 
            class="max-h-full max-w-full object-contain transition-transform duration-300 group-hover:scale-110" 
          />
        </div>

      </div>
    </div>
  </section>
 <section class="section-y bg-mint-light/20" id="contacto">
    <div class="container">
      
      <div class="grid gap-16 lg:grid-cols-2 items-start">
        
        <div class="reveal">
          <span class="section-label">Venta directa</span>
          <h2 class="section-title">Ven a vernos al Mercado</h2>
          <p class="mb-8 text-[1.05rem] leading-[1.8] text-black/60">
            Cada viernes bajamos del Pirineo con los huevos recién recogidos. Si quieres el producto más fresco y charlar un rato con nosotros, este es el lugar.
          </p>
          
          <div class="mb-8 flex flex-col gap-5">
            <div class="flex gap-4">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white shadow-sm text-[1.1rem]">📍</span>
              <p class="text-[0.95rem] text-black/75">
                <strong class="block text-black">Mercado Agroalimentario Unizar</strong>
                Plaza San Francisco, 50009 Zaragoza
              </p>
            </div>
            <div class="flex gap-4">
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-white shadow-sm text-[1.1rem]">⏰</span>
              <p class="text-[0.95rem] text-black/75">
                <strong class="block text-black">Horario</strong>
                Viernes de 9:00h a 13:30h
              </p>
            </div>
          </div>

          <div class="overflow-hidden rounded-2xl border border-black/10 shadow-sm grayscale transition-all duration-700 hover:grayscale-0">
            <iframe 
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2981.639103102179!2d-0.9008076235502369!3d41.641931680167176!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0xd59152467e412e3%3A0xaea834884a644a77!2sMercado%20Agroalimentario%20del%20Campus%20San%20Francisco!5e0!3m2!1ses!2ses!4v1776855204317!5m2!1ses!2ses" 
              width="100%" height="300" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
        </div>

        <div class="reveal">
