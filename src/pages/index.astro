---
// src/pages/index.astro
import BaseLayout from "@/layouts/BaseLayout.astro";

const title = "Arvipirineos — Huevos ecológicos del Pirineo Aragonés";
const description =
  "Microgranja ecológica de 1.000 gallinas en Santa Engracia de Jaca. Avicultura artesanal, huevos ecológicos y espárragos de producción regenerativa.";
---

<BaseLayout title={title} description={description}>

  <!-- ═══ STRUCTURED DATA ═══ -->
  <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://arvipirineos.es/#organization",
      "name": "Arvipirineos",
      "additionalType": [
        "https://en.wikipedia.org/wiki/Organic_farming",
        "https://en.wikipedia.org/wiki/Small_holding"
      ],
      "image": "https://kthulu.arvipirineos.es/wp-content/uploads/2024/08/photo_2024-08-06_14-32-50.jpg",
      "url": "https://arvipirineos.es",
      "telephone": "+34669757675",
      "priceRange": "€",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Santa Engracia de Jaca",
        "addressLocality": "Jaca",
        "addressRegion": "Huesca",
        "postalCode": "22728",
        "addressCountry": "ES"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 42.5458,
        "longitude": -0.6625
      },
      "knowsAbout": [
        "Producción agroalimentaria ecológica",
        "Avicultura artesanal",
        "Agricultura regenerativa",
        "Espárragos del Pirineo"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Productos Arvipirineos",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Product",
              "name": "Huevos ecológicos frescos"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Product",
              "name": "Espárragos orgánicos de temporada"
            }
          }
        ]
      }
    }
  </script>


  <!-- ═══ 1. HERO  ═══ -->
  <section class="sticky top-0 z-0 flex h-[100svh] items-center justify-center overflow-hidden text-center bg-black">
    <video autoplay muted loop playsinline class="absolute inset-0 h-full w-full object-cover opacity-60">
      <source src="https:///kthulu.arvipirineos.es/wp-content/uploads/2026/04/Gallinas-camperas-criadas-en-libertad.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-black/40"></div>
    <div class="container relative z-10 max-w-[850px] px-6 text-white">
      <span class="mb-8 inline-block rounded-full bg-mint/80 px-5 py-1.5 text-[0.75rem] font-semibold uppercase tracking-[0.15em] text-black">
        Microgranja ecológica · Santa Engracia de Jaca
      </span>
      <h1 class="font-display text-[clamp(2.5rem,6vw,5.5rem)] leading-[1.05]">
        Huevos ecológicos del Pirineo.<br />
        <span class="text-mint-light italic font-light">De gallinas que viven como reinas.</span>
      </h1>
      <p class="mx-auto mt-8 max-w-lg text-[1.25rem] font-medium">
        Criados sin prisa. Puestos con calma.
      </p>
      <div class="mt-12">
        <a href="#comprar" class="btn-primary">Pide tu caja</a>
      </div>
    </div>
  </section>


  <!-- ═══ CONTENIDO PRINCIPAL  ═══ -->
  <div class="relative z-10">


    <!-- ═══ 2. HISTORIA — Imagen IZQUIERDA ═══ -->
    <section class="section-y bg-mint-light">
      <div class="container">
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div class="contenedor-reveal-center rounded-3xl overflow-hidden">
            <img
              src="https:///kthulu.arvipirineos.es/wp-content/uploads/2026/04/photo_2026-04-21_11-40-03.jpg"
              alt="Pepa y Carlos en la granja Arvipirineos"
              class="imagen-reveal-center h-full w-full object-cover aspect-[4/5]"
            />
          </div>
          <div class="reveal">
            <span class="section-label">Así empezó todo</span>
            <h2 class="section-title">Del andamio al gallinero.</h2>
            <p class="text-[1.1rem] leading-[1.8] text-black/80">
              Marzo de 2020. El mundo se para. Y Carlos, después de muchos años subido a un andamio en la Jacetania, decide que es buen momento para bajar. Fue lo único que se podía hacer estando encerrados: adaptarnos a la realidad, poner los pies en la tierra literalmente e ir a su ritmo.
            </p>
            <p class="mt-4 text-[1.05rem] leading-[1.8] text-black/55">
              Empezamos con unas pocas gallinas en Santa Engracia de Jaca. Y resulta que el ritmo de la granja nos sentó bien.
            </p>
            <p class="mt-6 font-display italic text-lg text-egg">Hoy ya tenemos 1.000 gallinas. Y seguimos haciendo todo a mano.</p>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══ 3. PROCESOS A MANO — Imagen DERECHA ═══ -->
    <section class="section-y bg-mint-light">
      <div class="container">
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div class="reveal">
            <span class="section-label">Avicultura artesanal</span>
            <h2 class="section-title">Todos los procesos se hacen a mano.</h2>
            <p class="text-[1.1rem] leading-[1.8] text-black/80">
              Aquí nada está mecanizado. Cada huevo se recoge del nido, se revisa, se pesa y se marca uno a uno. Los nietos nos ayudan cuando vienen.
            </p>
            <p class="mt-4 text-[1.05rem] leading-[1.8] text-black/55">
              Y Niebla, nuestra jefa de seguridad, es una auténtica especialista en convencer a zorros y rapaces de que busquen el desayuno en otro sitio.
            </p>
          </div>
          <div class="contenedor-reveal-center rounded-3xl overflow-hidden">
            <img
              src="https:///kthulu.arvipirineos.es/wp-content/uploads/2026/04/photo_2026-04-21_12-43-50.jpg"
              alt="Niebla, la pastora de Arvipirineos"
              class="imagen-reveal-center h-full w-full object-cover aspect-[4/5]"
            />
          </div>
        </div>
      </div>
    </section>


    <!-- ═══ 4. BIENESTAR ANIMAL —  ═══ -->
    <section class="section-y bg-mint">
      <div class="container">
        <div class="reveal mb-12 text-center max-w-3xl mx-auto">
          <span class="section-label !text-black/40">Bienestar real</span>
            <h2 class="section-title">Menos Dubai, más Pirineo.</h2>
          <p class="mt-4 text-black/60 italic leading-relaxed">Si nuestras gallinas fueran personas estarían todo el día subiendo videos de lifestyle. Aire puro, comida ecológica, cero estrés laboral y siesta bajo los frutales. Vamos, que buscando el hashtag para sus stories. Y no es para menos.</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">

          <!-- Tarjeta 1: Menú 5 estrellas -->
          <div class="reveal bg-white p-8 rounded-2xl text-center">
            <div class="mb-4 mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-mint-light">
              <svg class="h-6 w-6 text-black/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2c1 3 3 5 6 5-1 3-3 5-6 9-3-4-5-6-6-9 3 0 5-2 6-5z"/>
                <path d="M8 15c-2 0-4 1-4 4h16c0-3-2-4-4-4"/>
                <line x1="9" y1="22" x2="15" y2="22"/>
              </svg>
            </div>
            <h3 class="font-display text-xl mb-3">Menú 5 estrellas</h3>
            <p class="text-sm text-black/60">Semillas, hierbas y bichitos. Pienso ecológico certificado para una dieta variada y natural.</p>
          </div>

          <!-- Tarjeta 2: Campo abierto -->
          <div class="reveal bg-white p-8 rounded-2xl text-center">
            <div class="mb-4 mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-mint-light">
              <svg class="h-6 w-6 text-black/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M17 8c2 0 4 1.5 4 4s-2 4-4 4"/>
                <path d="M7 8c-2 0-4 1.5-4 4s2 4 4 4"/>
                <path d="M12 4c2 0 3 2 3 4v4c0 3-1 6-3 8-2-2-3-5-3-8V8c0-2 1-4 3-4z"/>
              </svg>
            </div>
            <h3 class="font-display text-xl mb-3">A la sombra del manzano</h3>
            <p class="text-sm text-black/60">Hectáreas bajo los frutales. Agua fresca en verano y cobijo real en invierno.</p>
          </div>

          <!-- Tarjeta 3: Libertad total -->
          <div class="reveal bg-white p-8 rounded-2xl text-center">
            <div class="mb-4 mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-mint-light">
              <svg class="h-6 w-6 text-black/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 8v4l3 3"/>
                <path d="M7.5 7.5L12 12"/>
              </svg>
            </div>
            <h3 class="font-display text-xl mb-3">Libertad total</h3>
            <p class="text-sm text-black/60">No saben lo que es una jaula. Corretean y cotillean por donde les da la gana.</p>
          </div>

          <!-- Tarjeta 4: Cero estrés -->
          <div class="reveal bg-white p-8 rounded-2xl text-center">
            <div class="mb-4 mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-mint-light">
              <svg class="h-6 w-6 text-black/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3a6 6 0 0 0-6 6c0 5 6 9 6 9s6-4 6-9a6 6 0 0 0-6-6z"/>
                <circle cx="12" cy="9" r="2"/>
              </svg>
            </div>
            <h3 class="font-display text-xl mb-3">Cero estrés</h3>
            <p class="text-sm text-black/60">Al ritmo del sol y las estaciones. Las gallinas ponen cuando quieren, no cuando lo dice un reloj.</p>
          </div>

        </div>
      </div>
    </section>


    <!-- ═══ 5. PRODUCCIÓN LIMITADA  — Imagen IZQUIERDA ═══ -->
    <section class="section-y bg-mint-light">
      <div class="container">
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div class="contenedor-reveal-center rounded-3xl overflow-hidden">
            <img
              src="https:///kthulu.arvipirineos.es/wp-content/uploads/2026/04/arvipirineoskn1-scaled.webp"
              alt="Huevos ecológicos de Aragón Arvipirineos"
              class="imagen-reveal-center h-full w-full object-cover aspect-[4/5]"
            />
          </div>
          <div class="reveal">
            <span class="section-label">Avicultura artesanal</span>
            <h2 class="section-title">A veces no hay huevos. Y eso es lo natural.</h2>
            <p class="text-[1.1rem] leading-[1.8] text-black/80">
              Porque aquí manda la naturaleza. En la industria, las gallinas ponen a destajo: luces artificiales las 24 horas, cero descanso, máxima producción. Aquí respetamos sus biorritmos como si fueran de la familia (que lo son).
            </p>
            <p class="mt-4 text-[1.05rem] leading-[1.8] text-black/55">
              Eso significa que en invierno ponen menos (los días son más cortos y ellas descansan más), en verano ponen más (más luz natural, más actividad) y nunca forzamos nada.
            </p>
            <p class="mt-6 font-display italic text-lg text-egg">
              Producción limitada, sí. Pero cada huevo es el que tiene que ser: puesto con calma.
            </p>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══ 6. POR QUÉ SABEN DIFERENTE  — Imagen DERECHA ═══ -->
    <section class="section-y bg-mint-light">
      <div class="container">
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div class="reveal">
            <span class="section-label">Kilómetro cero</span>
            <h2 class="section-title">¿Por qué saben diferente? Porque SON diferentes.</h2>
            <p class="text-[1.1rem] leading-[1.8] text-black/80">
              Más Omega-3 (gracias a que las gallinas en libertad picotean lo que les da la gana), más vitaminas A y E, y ese color de yema que solo sale cuando una gallina come hierba fresca y no pienso industrial.
            </p>

            <div class="mt-8 space-y-5 border-t border-black/10 pt-8">
              <div class="flex gap-4">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-egg/20">
                  <svg class="h-4 w-4 text-black/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
                </span>
                <p class="text-[0.95rem] text-black/70"><strong>Un huevo que cambia con las estaciones.</strong> Como comen lo que ofrece el Pirineo en cada momento, la yema varía de tono. El sabor tiene matices. No es un defecto: es la prueba de que esto es real.</p>
              </div>
              <div class="flex gap-4">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-egg/20">
                  <svg class="h-4 w-4 text-black/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M9 12l2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
                </span>
                <p class="text-[0.95rem] text-black/70"><strong>Fresquitos, fresquitos.</strong> Del nido a tu cocina en un periquete. Cada huevo lleva su sello de garantía, puesto a mano, uno a uno.</p>
              </div>
              <div class="flex gap-4">
                <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-egg/20">
                  <svg class="h-4 w-4 text-black/70" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z"/></svg>
                </span>
                <p class="text-[0.95rem] text-black/70"><strong>Un huevo completo, no solo rico.</strong> Proteína de alta calidad, grasas buenas, más betacaroteno (por eso la yema es más naranja). Tu cuerpo lo nota aunque tú no te des cuenta.</p>
              </div>
            </div>
          </div>
          <div class="contenedor-reveal-center rounded-3xl overflow-hidden">
            <img
              src="https:///kthulu.arvipirineos.es/wp-content/uploads/2024/08/photo_2024-08-06_14-32-39-1.jpg"
              alt="Yema naranja de huevo ecológico Arvipirineos"
              class="imagen-reveal-center h-full w-full object-cover aspect-[4/5]"
            />
          </div>
        </div>
      </div>
    </section>


    <!-- ═══ 7. ESPÁRRAGOS — Imagen IZQUIERDA ═══ -->
    <section class="section-y bg-white overflow-hidden">
      <div class="container">
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div class="contenedor-reveal-center rounded-3xl overflow-hidden">
            <img
              src="https:///kthulu.arvipirineos.es/wp-content/uploads/2024/08/photo_2024-08-06_14-32-29.jpg"
              alt="Espárragos ecológicos Arvipirineos"
              class="imagen-reveal-center h-full w-full object-cover aspect-[4/5]"
            />
          </div>
          <div class="reveal">
            <span class="section-label">De la huerta del Pirineo</span>
            <h2 class="section-title">Los espárragos más esperados de Jaca.</h2>
            <p class="text-[1.1rem] leading-[1.8] text-black/80">
              La tierra de Santa Engracia no solo nos da huevos. Cultivamos espárragos orgánicos, tiernos y con el sabor auténtico de la huerta del Pirineo.
            </p>
            <p class="mt-4 text-[1.05rem] leading-[1.8] text-black/55">
              Al ser un cultivo 100% natural, su aparición es un evento limitado. ¡Avisamos en redes sociales en cuanto empieza la cosecha!
            </p>
            <div class="mt-8">
              <a href="https://www.instagram.com/arvipirineos.eco" target="_blank" rel="noopener" class="group inline-flex items-center gap-3 rounded-full bg-black px-6 py-3 text-[0.9rem] font-bold text-white no-underline transition-all hover:-translate-y-1 hover:bg-egg hover:text-black">
                <svg class="h-5 w-5 fill-current" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                Síguenos en Instagram
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>


    <!-- ═══ 8. PRODUCCIÓN REGENERATIVA — Imagen DERECHA ═══ -->
    <section class="section-y bg-mint-light">
      <div class="container">
        <div class="grid items-center gap-16 md:grid-cols-2">
          <div class="reveal">
            <span class="section-label">Producción regenerativa</span>
            <h2 class="section-title">Aquí no se tira nada.</h2>
            <p class="text-[1.1rem] leading-[1.8] text-black/80">
              Las gallinas compostan, el compost alimenta la huerta, y la huerta nos alimenta a todos. Producción regenerativa sin llamarla así.
            </p>
            <p class="mt-4 text-[1.05rem] leading-[1.8] text-black/55">
              Al elegir nuestros huevos, apoyas una forma de hacer las cosas que tiene sentido: local, ética, sostenible.
            </p>
          </div>
          <div class="contenedor-reveal-center rounded-3xl overflow-hidden">
            <img
              src="https:///kthulu.arvipirineos.es/wp-content/uploads/2024/08/Sin-titulo-51.png"
              alt="Ciclo regenerativo Arvipirineos"
              class="imagen-reveal-center h-full w-full object-cover aspect-[4/5]"
            />
          </div>
        </div>
      </div>
    </section>


    <!-- ═══ 9. CERTIFICACIONES  ═══ -->
    <section class="section-y bg-mint">
      <div class="container max-w-3xl">
        <div class="reveal text-center">
          <span class="section-label !text-black/40">Garantía ecológica</span>
          <h2 class="section-title">Nuestros huevos tienen la más alta certificación.</h2>
          <p class="mt-4 text-black/60 mb-12">Todo nuestro trabajo tiene su reconocimiento. Lo avalan los organismos que más saben de producción ecológica en Europa.</p>
        </div>
        <div class="grid gap-6 sm:grid-cols-2">
          <div class="reveal flex flex-col items-center bg-white rounded-2xl p-8 text-center">
            <img
              src="https:///kthulu.arvipirineos.es/wp-content/uploads/2024/08/Recurso-1-100.jpg"
              alt="Certificación CAAE"
              class="h-20 w-auto object-contain mb-6"
            />
            <h3 class="font-display text-lg mb-2">Certificación CAAE</h3>
            <p class="text-sm text-black/60">Organismo de control autorizado para la certificación de producción ecológica en España.</p>
          </div>
          <div class="reveal flex flex-col items-center bg-white rounded-2xl p-8 text-center">
            <img
              src="https:///kthulu.arvipirineos.es/wp-content/uploads/2024/08/Logo-agricultura-ecologica.jpg"
              alt="Sello Eurohoja"
              class="h-20 w-auto object-contain mb-6"
              />
            <h3 class="font-display text-lg mb-2">Sello Ecológico UE</h3>
            <p class="text-sm text-black/60">Certificación de la Unión Europea que garantiza el cumplimiento de la normativa ecológica.</p>
          </div>
        </div>
      </div>
    </section>
   
    <!-- ═══ NOS HAS VISTO EN ═══ -->
    <section class="section-y bg-mint">
      <div class="container max-w-4xl">
        <div class="reveal text-center mb-12">
          <span class="section-label !text-black/40">Prensa y medios</span>
          <h2 class="section-title">Nos has visto en</h2>
        </div>
        <div class="grid grid-cols-2 gap-8 sm:grid-cols-4 items-center">
          <div class="reveal flex items-center justify-center p-4 brightness-0 opacity-50 transition-all duration-500 hover:brightness-100 hover:opacity-100">
            <img src="https:///kthulu.arvipirineos.es/wp-content/uploads/2026/04/Ruralforks_white-150x150-1.png" alt="Rural Forks" class="h-20 w-auto object-contain" />
          </div>
          <div class="reveal flex items-center justify-center p-4 brightness-0 opacity-50 transition-all duration-500 hover:brightness-100 hover:opacity-100">
            <img src="https:///kthulu.arvipirineos.es/wp-content/uploads/2026/04/Sin-titulo-6.png" alt="Heraldo de Aragón" class="h-20 w-auto object-contain" />
          </div>
          <div class="reveal flex items-center justify-center p-4 brightness-0 opacity-50 transition-all duration-500 hover:brightness-100 hover:opacity-100">
            <img src=https:///kthulu.arvipirineos.es/wp-content/uploads/2026/04/Logo_Aragon_TV_2026.png alt="Aragón Televisión" class="h-20 w-auto object-contain" />
          </div>
          <div class="reveal flex items-center justify-center p-4 brightness-0 opacity-50 transition-all duration-500 hover:brightness-100 hover:opacity-100">
